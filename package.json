{
  "name": "celine-playwright-pom",
  "version": "0.1.0",
  "private": true,
  "description": "Celine E2E Playwright tests across regions (FR/US/JP/AU/TH).",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm audit",
    "preview:email": "node scripts/preview-email-report.js",
    "test:unit": "playwright test --project=unit",
    "test:e2e": "playwright test tests/celine-purchase.spec.ts",
    "test:e2e:headed": "playwright test tests/celine-purchase.spec.ts --headed --workers=1",
    "test:e2e:debug": "playwright test tests/celine-purchase.spec.ts --debug"
  },
  "dependencies": {
    "dotenv": "16.6.1",
    "nodemailer": "8.0.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.57.0",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "7.0.5",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2"
  },
  "overrides": {
    "fast-xml-parser": "5.7.3"
  },
  "engines": {
    "node": ">=22"
  }
}
