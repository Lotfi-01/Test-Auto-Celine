# Playwright E2E Tests - Environment Variables
# Copy this file to .env and fill in the actual values

# HTTP Basic Authentication (required for dev environment)
HTTP_AUTH_USER=
HTTP_AUTH_PASSWORD=

# Test User Data
TEST_EMAIL=
TEST_USER_FIRSTNAME=
TEST_USER_LASTNAME=
TEST_USER_PHONE=

# Regional emails and passwords for registered customer checkout login (email + password)
# TEST_EMAIL_<REGION> and TEST_PASSWORD_<REGION> (e.g. JP, AU, NL, etc.)
TEST_EMAIL_JP=japan_tva_test1@yopmail.com
TEST_PASSWORD_JP=Test1234!
TEST_EMAIL_NL=nl_customer_lotfi@yopmail.com
TEST_PASSWORD_NL=Test1234!
BASE_URL_NL=https://dev.celine.com
TEST_PRODUCT_URL_NL=/en-nl/women/handbags/triomphe-canvas/teen-triomphe-bag-in-triomphe-canvas-and-calfskin-188882BZ4.04LU.html

# Test Address
TEST_ADDRESS_STREET=
TEST_ADDRESS_CITY=
TEST_ADDRESS_POSTAL_CODE=
TEST_ADDRESS_COUNTRY=

# Test Payment (Adyen test cards only)
TEST_CARD_NUMBER=
TEST_CARD_HOLDER=
TEST_CARD_EXPIRY=
TEST_CARD_CVV=

# Environment Configuration
BASE_URL=https://dev.celine.com
BASE_URL_US=https://dev.celine.com
TEST_PRODUCT_URL=/fr-fr/celine-boutique-femme/mini-sacs/trio-flap/trio-flap-agneau-lisse-10P862O86.28PO.html

# Timeouts (optional - defaults will be used if not set)
# TIMEOUT_ELEMENT=10000
# TIMEOUT_PAGE_LOAD=30000
# TIMEOUT_TEST=120000

# Email Reporting (optional - for automatic test reports)
# SMTP Configuration - Use your email provider's SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Report Recipients (comma-separated for multiple)
REPORT_EMAIL_TO=qa-team@example.com
REPORT_EMAIL_CC=manager@example.com

# Enable/Disable automatic email reports after tests
SEND_EMAIL_REPORT=false

# Order Cleanup Strategy (after successful email send)
# Options:
#   - 'all'  : Clear all orders from database (fresh start each run)
#   - 'old'  : Keep only recent orders (delete orders older than KEEP_ORDERS_DAYS)
#   - (empty): Keep all orders for audit trail (default)
CLEAR_ORDERS_AFTER_EMAIL=

# Number of days to keep orders when using CLEAR_ORDERS_AFTER_EMAIL=old
# Default: 7 days
KEEP_ORDERS_DAYS=7
