# =============================================================================
# Celine Playwright E2E — Environment Variables (example)
#
# Copy this file to `.env` and fill values from your secret store (Vault,
# 1Password, GitHub Actions secrets, etc.). Never commit real credentials.
#
# Only tests that use a given credential require the corresponding variable.
# Unit tests, lint and typecheck run without any of these.
# =============================================================================

# ---------------------------------------------------------------------------
# HTTP Basic Auth to reach the Celine dev sandbox (required for all E2E)
# ---------------------------------------------------------------------------
HTTP_AUTH_USER=
HTTP_AUTH_PASSWORD=

# ---------------------------------------------------------------------------
# Base URLs (per region — override BASE_URL for a specific market)
# ---------------------------------------------------------------------------
BASE_URL=
BASE_URL_FR=
BASE_URL_US=
BASE_URL_JP=
BASE_URL_AU=
BASE_URL_TH=
BASE_URL_NL=

# ---------------------------------------------------------------------------
# Regional test accounts (Celine registered-customer login)
# One <email, password> per region. Empty = region skipped for registered flow.
# ---------------------------------------------------------------------------
TEST_EMAIL_FR=
TEST_PASSWORD_FR=

TEST_EMAIL_US=
TEST_PASSWORD_US=

TEST_EMAIL_JP=
TEST_PASSWORD_JP=

TEST_EMAIL_AU=
TEST_PASSWORD_AU=

TEST_EMAIL_TH=
TEST_PASSWORD_TH=

TEST_EMAIL_NL=
TEST_PASSWORD_NL=

# ---------------------------------------------------------------------------
# Product URLs (comma-separated for multi-product cart)
# ---------------------------------------------------------------------------
TEST_PRODUCT_URL_FR=
TEST_PRODUCT_URL_US=
TEST_PRODUCT_URL_JP=
TEST_PRODUCT_URL_AU=
TEST_PRODUCT_URL_TH=
TEST_PRODUCT_URL_NL=

# ---------------------------------------------------------------------------
# Delivery mode per region: "pickup" (Click & Collect) or empty/anything else = "home"
# ---------------------------------------------------------------------------
TEST_DELIVERY_MODE_FR=
TEST_DELIVERY_MODE_US=
TEST_DELIVERY_MODE_JP=
TEST_DELIVERY_MODE_AU=
TEST_DELIVERY_MODE_TH=
TEST_DELIVERY_MODE_NL=

# ---------------------------------------------------------------------------
# Test cards
#
# Use ONLY the sandbox card numbers officially documented by Adyen / Cybersource.
#  - Adyen test cards      : https://docs.adyen.com/development-resources/testing/test-card-numbers/
#  - Cybersource test cards: https://developer.cybersource.com/hello-world/testing-guide.html
# Never store production PAN, real cardholder data or shared personal cards.
# ---------------------------------------------------------------------------
TEST_CARD_NUMBER_FR=
TEST_CARD_EXPIRY_FR=
TEST_CARD_CVV_FR=
TEST_CARDHOLDER_FR=

TEST_CARD_NUMBER_US=
TEST_CARD_EXPIRY_US=
TEST_CARD_CVV_US=
TEST_CARDHOLDER_US=

TEST_CARD_NUMBER_JP=
TEST_CARD_EXPIRY_JP=
TEST_CARD_CVV_JP=
TEST_CARDHOLDER_JP=

# AU: TEST_CARD_SCHEME_AU=eftpos switches to the AU EFTPos test card (3DS-triggering)
TEST_CARD_SCHEME_AU=
TEST_CARD_NUMBER_AU=
TEST_CARD_EXPIRY_AU=
TEST_CARD_CVV_AU=
TEST_CARDHOLDER_AU=

TEST_CARD_NUMBER_TH=
TEST_CARD_EXPIRY_TH=
TEST_CARD_CVV_TH=
TEST_CARDHOLDER_TH=

TEST_CARD_NUMBER_NL=
TEST_CARD_EXPIRY_NL=
TEST_CARD_CVV_NL=
TEST_CARDHOLDER_NL=

# ---------------------------------------------------------------------------
# PayPal sandbox account (shared across regions)
# Provision a dedicated sandbox buyer from your PayPal developer dashboard.
# ---------------------------------------------------------------------------
PAYPAL_EMAIL=
PAYPAL_PASSWORD=

# ---------------------------------------------------------------------------
# Afterpay sandbox account (AU only)
# Provision from the Afterpay sandbox portal — do not reuse a personal account.
# ---------------------------------------------------------------------------
AFTERPAY_AU_EMAIL=
AFTERPAY_AU_PASSWORD=

# ---------------------------------------------------------------------------
# Payment method selector (used by tests/celine-purchase.spec.ts)
# card | paypal | afterpay
# ---------------------------------------------------------------------------
TEST_PAYMENT_METHOD=

# ---------------------------------------------------------------------------
# Optional testing knobs
# ---------------------------------------------------------------------------
# Mock the payment API rather than hitting Adyen/Cybersource sandbox
MOCK_PAYMENT_API=

# Persist test results tracking (used for the email report)
TRACK_RESULTS=

# ---------------------------------------------------------------------------
# PII policy
#
# By default, reports and JSON trackers store MASKED emails only (e.g. lo***@***.com).
# Set to `true` ONLY on trusted, access-restricted runners if raw emails are
# required for cross-system correlation. Never enable this in a shared repo.
# ---------------------------------------------------------------------------
INCLUDE_PII_IN_REPORT=false

# ---------------------------------------------------------------------------
# Email reporting (optional — enables the SMTP report from global-teardown)
# ---------------------------------------------------------------------------
SEND_EMAIL_REPORT=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=
REPORT_EMAIL_CC=

# ---------------------------------------------------------------------------
# Order cleanup after successful email send
# Options: 'all' | 'old' | (empty = keep all)
# ---------------------------------------------------------------------------
CLEAR_ORDERS_AFTER_EMAIL=
KEEP_ORDERS_DAYS=7
